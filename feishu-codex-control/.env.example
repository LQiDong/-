FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated Feishu sender ids allowed to control this computer.
# Accepts open_id, user_id, or union_id values from incoming events.
FEISHU_ALLOWED_IDS=ou_xxxxxxxxxxxxx

# Workspace controlled by safe preset actions.
HOMEPAGE_DIR=D:\DESK\AI产品经理\个人主页

# Optional: require the local operator to approve sensitive actions from stdin.
# Set to false only when you are comfortable with remote preset execution.
REQUIRE_LOCAL_APPROVAL=true

# Optional command timeout.
ACTION_TIMEOUT_MS=120000
